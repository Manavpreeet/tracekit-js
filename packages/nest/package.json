{
  "name": "@tracekit/nest",
  "version": "0.1.0",
  "description": "NestJS integration for TraceKit request correlation.",
  "author": "Manavpreet Singh <manavpreeetsingh@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Manavpreeet/tracekit-js/tree/main/packages/nest#readme",
  "bugs": {
    "url": "https://github.com/Manavpreeet/tracekit-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Manavpreeet/tracekit-js.git",
    "directory": "packages/nest"
  },
  "keywords": [
    "tracekit",
    "nestjs",
    "request-id",
    "correlation-id",
    "interceptor"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18.18.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@tracekit/core": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0 || ^10.0.0",
    "@nestjs/core": "^11.0.0 || ^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
